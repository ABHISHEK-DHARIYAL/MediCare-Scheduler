{
  "name": "emergency-room-scheduler",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "cd backend && tsx server.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && (g++ -O3 scheduler.cpp -o scheduler || echo 'g++ not found, skipping C++ compilation')",
    "start": "cd backend && node dist/server.js",
    "lint": "cd frontend && tsc --noEmit && cd ../backend && tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
